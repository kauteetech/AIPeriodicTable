            { symbol: 'Mm', name: 'Multimodal Models', fullName: 'Multimodal Models', row: 2, family: 'models', description: 'Models that process images and audio in addition to text', concept: 'Models that process images and audio in addition to text', properties: ['Extend LLM capabilities beyond text', 'Enable vision and audio understanding', 'Composition of multiple modality models'], role: 'Composition of Lg that adds multimodal capabilities' },

