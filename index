            { symbol: 'Rt', name: 'Red Teaming', fullName: 'Red Teaming', row: 3, family: 'validation', description: 'Adversarial testing to break the AI', concept: 'Adversarial testing: jailbreaks, prompt injection, data exfiltration attempts to "break the AI"', properties: ['Proactive safety testing', 'Identifies vulnerabilities before deployment', 'Ensures robustness against attacks'], role: 'Deployment-stage safety validation' },
            { symbol: 'Sm', name: 'Small Models', fullName: 'Small Models', row: 3, family: 'models', description: 'Distilled, specialized, fast, cheap models', concept: 'Distilled, specialized, fast, cheap models that may run on a phone', properties: ['Optimized for efficiency', 'Can run on edge devices', 'Trade-off: capability for speed and cost'], role: 'Specialized, efficient models for deployment' },

            // Row 4: Emerging
            { symbol: 'Ma', name: 'Multi-Agent Systems', fullName: 'Multi-Agent Systems', row: 4, family: 'reactive', description: 'Multiple AIs collaborating and specializing', concept: 'Multiple AIs collaborating, specializing, debating, coordinating (e.g., research agent, writer agent, critic agent)', properties: ['Reactive family taken to the extreme', 'Emergent collective intelligence', 'Specialization and coordination'], role: 'Emerging pattern of multiple autonomous agents' },
            { symbol: 'Sy', name: 'Synthetic Data', fullName: 'Synthetic Data', row: 4, family: 'retrieval', description: 'Using AI to generate training data for AI', concept: 'Using AI to generate training data for AI when real data is limited', properties: ['Increasingly important as we hit limits of available real data', 'AI-generated training data for AI systems', 'Addresses data scarcity challenges'], role: 'Emerging data generation pattern' },
            { symbol: 'In', name: 'Interpretability', fullName: 'Interpretability', row: 4, family: 'validation', description: 'Understanding why a model behaves as it does', concept: 'Understanding why a model behaves as it does; finding neurons responsible for specific behaviors', properties: ['Frontier safety work', 'Enables transparency and trust', 'Identifies model reasoning'], role: 'Emerging safety and understanding paradigm' },
            { symbol: 'Th', name: 'Thinking Models', fullName: 'Thinking Models', row: 4, family: 'models', description: 'Models that spend time reasoning instead of immediate answers', concept: 'Models that spend time reasoning instead of immediate answers; chain-of-thought built directly into architecture, test-time compute scaling', properties: ['Chain-of-thought built directly into architecture', 'Test-time compute scaling', 'Tend to be the smartest models today'], role: 'Emerging frontier in model capabilities' },
        ];

        const PATTERNS = [
            { title: 'AI Image Generators', description: 'Generate images from text prompts', flow: [{ symbol: 'Pr', text: 'Prompt', color: '#D97706' }, { symbol: 'Mm', text: 'Multimodal', color: '#7C3AED' }], example: 'DALL-E, Midjourney, Stable Diffusion' },
            { title: 'Code Assistants', description: 'Understand and generate code', flow: [{ symbol: 'Ft', text: 'Fine-tune', color: '#0891B2' }, { symbol: 'Pr', text: 'Prompt', color: '#D97706' }, { symbol: 'Lg', text: 'LLM', color: '#7C3AED' }], example: 'GitHub Copilot, Cursor, Claude' },
            { title: 'Search & Recommendation', description: 'Find relevant information', flow: [{ symbol: 'Em', text: 'Embed', color: '#0891B2' }, { symbol: 'Vx', text: 'Vector DB', color: '#0891B2' }], example: 'Semantic search, recommendation engines' },
            { title: 'Autonomous Workflows', description: 'Complete tasks automatically', flow: [{ symbol: 'Ag', text: 'Agent', color: '#D97706' }, { symbol: 'Fc', text: 'Function', color: '#D97706' }, { symbol: 'Fw', text: 'Framework', color: '#16A34A' }], example: 'Zapier AI, Make, n8n' },
        ];

        const RAG_FLOW = [
            { step: 1, title: 'Em (Embeddings)', description: 'Convert documents to numerical vectors', color: '#0891B2' },
            { step: 2, title: 'Vx (Vector Database)', description: 'Store embeddings for semantic search', color: '#0891B2' },
            { step: 3, title: 'Rg (RAG)', description: 'Retrieve relevant chunks at query time', color: '#16A34A' },
            { step: 4, title: 'Pr (Prompt)', description: 'Augment user prompt with retrieved context', color: '#D97706' },
            { step: 5, title: 'Lg (LLM)', description: 'Generate grounded answers', color: '#7C3AED' },
            { step: 6, title: 'Gr (Guardrails)', description: 'Optional safety layer', color: '#DC2626' },
        ];

        const AGENT_FLOW = [
            { step: 1, title: 'Ag (Agent)', description: 'Think and plan tasks', color: '#D97706' },
            { step: 2, title: 'Fc (Function Calling)', description: 'Act by calling external tools', color: '#D97706' },
            { step: 3, title: 'Observe', description: 'Analyze results', color: '#0891B2' },
            { step: 4, title: 'Repeat', description: 'Loop until goal achieved', color: '#16A34A' },
            { step: 5, title: 'Fw (Framework)', description: 'Deploy within orchestration platform', color: '#16A34A' },
        ];

        // ============ STATE ============
        let selectedFamily = null;
        let selectedRow = null;
        let selectedElement = null;
        let selectedChallengeElements = new Set();
        let currentReaction = 'rag';

        // ============ UTILITY FUNCTIONS ============
        function getElementBySymbol(symbol) {
            return ELEMENTS.find(el => el.symbol === symbol);
        }

        function shouldShowElement(element) {
            if (selectedFamily && element.family !== selectedFamily) return false;
            if (selectedRow && element.row !== selectedRow) return false;
            return true;
        }

        function createElementCard(element) {
            const familyColor = FAMILIES[element.family].color;
            const familyLightColor = FAMILIES[element.family].lightColor;
            const isHidden = !shouldShowElement(element);

            const card = document.createElement('div');
            card.className = `element-card ${isHidden ? 'hidden' : ''} ${selectedElement?.symbol === element.symbol ? 'selected' : ''}`;
            card.style.borderColor = isHidden ? undefined : familyColor;
            card.style.backgroundColor = isHidden ? undefined : familyLightColor;
            card.style.setProperty('--family-color', familyColor);

            card.innerHTML = `
                <div class="element-card-content">
                    <div class="element-symbol" style="color: ${familyColor};">${element.symbol}</div>
                    <div class="element-name">${element.name}</div>
                    <div class="element-family" style="color: ${familyColor};">${FAMILIES[element.family].name}</div>
                    <p class="element-description">${element.description}</p>
                    <div class="element-hint">Click for details →</div>
                </div>
            `;

            card.addEventListener('click', () => showDetailPanel(element));
            return card;
        }

        function createEmptySlot() {
            const slot = document.createElement('div');
            slot.className = 'empty-slot';
            slot.textContent = '(not defined)';
            return slot;
        }

        function renderPeriodicTable() {
            const table = document.getElementById('periodicTable');
            table.innerHTML = '';

            for (let row = 1; row <= 4; row++) {
                const rowSection = document.createElement('div');
                rowSection.className = 'row-section';

                const rowHeader = document.createElement('div');
                rowHeader.className = 'row-header';
                rowHeader.innerHTML = `
                    <div class="row-label">
                        <h2>Row ${row}</h2>
                        <p>${ROWS[row].name}</p>
                    </div>
                    <div class="row-divider"></div>
                `;
                rowSection.appendChild(rowHeader);

                const familyHeaders = document.createElement('div');
                familyHeaders.className = 'family-headers';
                Object.entries(FAMILIES).forEach(([key, family]) => {
                    const header = document.createElement('div');
                    header.className = 'family-header';
                    header.innerHTML = `
                        <div class="family-header-title" style="color: ${family.color};">${family.name}</div>
                        <div class="family-header-desc">${family.description}</div>
                    `;
                    familyHeaders.appendChild(header);
                });
                rowSection.appendChild(familyHeaders);

                const grid = document.createElement('div');
                grid.className = 'elements-grid';

                Object.keys(FAMILIES).forEach(familyKey => {
                    const element = ELEMENTS.find(el => el.row === row && el.family === familyKey);
                    if (element) {
                        grid.appendChild(createElementCard(element));
                    } else {
                        grid.appendChild(createEmptySlot());
                    }
                });

                rowSection.appendChild(grid);
                table.appendChild(rowSection);
            }
        }

        function showDetailPanel(element) {
            selectedElement = element;
            const familyColor = FAMILIES[element.family].color;
            const familyLightColor = FAMILIES[element.family].lightColor;

            const panel = document.getElementById('detailPanel');
            const overlay = document.getElementById('detailOverlay');

            panel.innerHTML = `
                <div class="detail-header" style="background-color: ${familyLightColor};">
                    <div class="detail-header-top">
                        <div>
                            <div class="detail-symbol" style="color: ${familyColor};">${element.symbol}</div>
                            <div class="detail-title">${element.fullName}</div>
                        </div>
                        <button class="detail-close">×</button>
                    </div>
                </div>
                <div class="detail-content">
                    <div class="detail-section">
                        <div class="detail-section-title">Family</div>
                        <div class="detail-section-text">${FAMILIES[element.family].name}</div>
                    </div>
                    <div class="detail-section">
                        <div class="detail-section-title">Row</div>
                        <div class="detail-section-text">${ROWS[element.row].name}</div>
                    </div>
                    <div class="detail-section">
                        <div class="detail-section-title">Description</div>
                        <div class="detail-section-text">${element.description}</div>
                    </div>
                    <div class="detail-section">
                        <div class="detail-section-title">Concept</div>
                        <div class="detail-section-text">${element.concept}</div>
                    </div>
                    ${element.role ? `
                    <div class="detail-section">
                        <div class="detail-section-title">Role</div>
                        <div class="detail-section-text">${element.role}</div>
                    </div>
                    ` : ''}
                    ${element.properties ? `
                    <div class="detail-section">
                        <div class="detail-section-title">Properties</div>
                        <ul class="detail-list">
                            ${element.properties.map(prop => `<li>${prop}</li>`).join('')}
                        </ul>
                    </div>
                    ` : ''}
                    ${element.examples ? `
                    <div class="detail-section">
                        <div class="detail-section-title">Examples</div>
                        <ul class="detail-list">
                            ${element.examples.map(ex => `<li>${ex}</li>`).join('')}
                        </ul>
                    </div>
                    ` : ''}
                </div>
            `;

            panel.style.display = 'block';
            overlay.style.display = 'block';

            const closeBtn = panel.querySelector('.detail-close');
            closeBtn.addEventListener('click', closeDetailPanel);
            overlay.addEventListener('click', closeDetailPanel);

            renderPeriodicTable();
        }

        function closeDetailPanel() {
            selectedElement = null;
            document.getElementById('detailPanel').style.display = 'none';
            document.getElementById('detailOverlay').style.display = 'none';
            renderPeriodicTable();
        }

        function renderReactionsView() {
            const ragFlow = document.getElementById('rag-flow');
            ragFlow.innerHTML = RAG_FLOW.map((step, idx) => `
                <div class="flow-step">
                    <div class="step-number" style="background-color: ${step.color};">${step.step}</div>
                    <div class="step-content">
                        <h4>${step.title}</h4>
                        <p>${step.description}</p>
                    </div>
                </div>
                ${idx < RAG_FLOW.length - 1 ? '<div class="flow-divider"><div class="flow-divider-line"></div></div>' : ''}
            `).join('');

            const agentFlow = document.getElementById('agent-flow');
            agentFlow.innerHTML = AGENT_FLOW.map((step, idx) => `
                <div class="flow-step">
                    <div class="step-number" style="background-color: ${step.color};">${step.step}</div>
                    <div class="step-content">
                        <h4>${step.title}</h4>
                        <p>${step.description}</p>
                    </div>
                </div>
                ${idx < AGENT_FLOW.length - 1 ? '<div class="flow-divider"><div class="flow-divider-line"></div></div>' : ''}
            `).join('');
        }

        function renderPatternsView() {
            const grid = document.getElementById('patternsGrid');
            grid.innerHTML = PATTERNS.map(pattern => `
                <div class="pattern-card">
                    <div class="pattern-title">${pattern.title}</div>
                    <div class="pattern-desc">${pattern.description}</div>
                    <div class="pattern-flow">
                        ${pattern.flow.map((el, idx) => `
                            <div class="pattern-element">
                                <div class="pattern-element-circle" style="background-color: ${el.color};">${el.symbol}</div>
                                <div class="pattern-element-label">${el.text}</div>
                            </div>
                            ${idx < pattern.flow.length - 1 ? '<div class="pattern-arrow">→</div>' : ''}
                        `).join('')}
                    </div>
                    <div class="pattern-example">
                        <div class="pattern-example-label">Examples:</div>
                        <div class="pattern-example-text">${pattern.example}</div>
                    </div>
                </div>
            `).join('');
        }

        function renderChallengeView() {
            const container = document.getElementById('challengeElements');
            container.innerHTML = ELEMENTS.map(el => `
                <button class="element-selector ${selectedChallengeElements.has(el.symbol) ? 'selected' : ''}" data-symbol="${el.symbol}">
                    <div style="font-weight: 700; color: ${FAMILIES[el.family].color};">${el.symbol}</div>
                    <div style="font-size: 0.625rem; color: var(--color-gray-600);">${el.name}</div>
                </button>
            `).join('');

            document.querySelectorAll('.element-selector').forEach(btn => {
                btn.addEventListener('click', () => {
                    const symbol = btn.dataset.symbol;
                    if (selectedChallengeElements.has(symbol)) {
                        selectedChallengeElements.delete(symbol);
                    } else {
                        selectedChallengeElements.add(symbol);
                    }
                    renderChallengeView();
                });
            });

            document.getElementById('clearBtn').style.display = selectedChallengeElements.size > 0 ? 'block' : 'none';
        }

        function analyzeCombination() {
            if (selectedChallengeElements.size === 0) {
                showFeedback('Please select at least one element to analyze.');
                return;
            }

            const selected = ELEMENTS.filter(el => selectedChallengeElements.has(el.symbol));
            const families = new Set(selected.map(el => el.family));
            const hasSafety = selected.some(el => el.family === 'validation');
            const hasOrchestration = selected.some(el => el.family === 'orchestration');
            const hasModels = selected.some(el => el.family === 'models');

            let analysis = `You've selected ${selected.length} element${selected.length > 1 ? 's' : ''}: ${selected.map(el => el.symbol).join(', ')}.\n\n`;
            analysis += `Families involved: ${Array.from(families).map(f => FAMILIES[f].name).join(', ')}\n\n`;

            if (selected.length === 1) {
                analysis += `This is a primitive element. Most AI systems combine multiple elements to create reactions.\n\n`;
            } else if (selected.length === 2) {
                analysis += `This is a simple composition. You're combining two elements.\n\n`;
            } else {
                analysis += `This is a complex system with ${selected.length} elements.\n\n`;
            }

            if (!hasSafety) {
                analysis += `⚠️ Safety Alert: You're missing a validation element (Guardrails, Red Teaming, or Interpretability). Consider adding safety layers.\n\n`;
            }

            if (!hasModels) {
                analysis += `⚠️ Missing Models: Every AI system needs a model (LLM, Multimodal, Small Model, or Thinking Model).\n\n`;
            }

            if (hasOrchestration && selected.length === 1) {
                analysis += `💡 Insight: You selected an orchestration element alone. Consider pairing it with reactive or retrieval elements.\n\n`;
            }

            analysis += `This combination represents a ${selected.length}-element AI system.`;

            showFeedback(analysis);
        }

        function showFeedback(text) {
            const container = document.getElementById('feedbackContainer');
            container.innerHTML = `
                <div class="feedback-box amber">
                    <h4>Analysis</h4>
                    <p>${text}</p>
                </div>
            `;
        }

        // ============ EVENT LISTENERS ============
        document.querySelectorAll('.nav-tab').forEach(btn => {
            btn.addEventListener('click', () => {
                const tabName = btn.dataset.tab;
                document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(tabName).classList.add('active');

                if (tabName === 'reactions') renderReactionsView();
                if (tabName === 'patterns') renderPatternsView();
                if (tabName === 'challenge') renderChallengeView();
            });
        });

        document.querySelectorAll('.reaction-tab').forEach(btn => {
            btn.addEventListener('click', () => {
                const reaction = btn.dataset.reaction;
                currentReaction = reaction;
                document.querySelectorAll('.reaction-tab').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.reaction-content').forEach(c => c.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(reaction + '-content').classList.add('active');
            });
        });

        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const filterType = btn.dataset.filter;
                const value = btn.dataset.value;

                if (filterType === 'family') {
                    if (value === 'all') {
                        selectedFamily = null;
                        document.querySelectorAll('[data-filter="family"]').forEach(b => {
                            b.classList.toggle('all-active', b.dataset.value === 'all');
                            b.classList.remove('active');
                        });
                    } else {
                        selectedFamily = value;
                        document.querySelectorAll('[data-filter="family"]').forEach(b => {
                            b.classList.remove('all-active');
                            b.classList.toggle('active', b.dataset.value === value);
                        });
                    }
                } else if (filterType === 'row') {
                    if (value === 'all') {
                        selectedRow = null;
                        document.querySelectorAll('[data-filter="row"]').forEach(b => {
                            b.classList.toggle('all-active', b.dataset.value === 'all');
                            b.classList.remove('active');
                        });
                    } else {
                        selectedRow = parseInt(value);
                        document.querySelectorAll('[data-filter="row"]').forEach(b => {
                            b.classList.remove('all-active');
                            b.classList.toggle('active', b.dataset.value === value);
                        });
                    }
                }

                renderPeriodicTable();
            });
        });

        document.getElementById('analyzeBtn').addEventListener('click', analyzeCombination);
        document.getElementById('clearBtn').addEventListener('click', () => {
            selectedChallengeElements.clear();
            document.getElementById('feedbackContainer').innerHTML = '';
            renderChallengeView();
        });

        // ============ INITIALIZATION ============
        renderPeriodicTable();
    </script>
</body>
</html>
